# ============================================
# Meta WhatsApp Business Cloud API
# ============================================
# Token de acceso permanente de la WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_api_token_here

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Token personalizado para verificar el webhook (tú lo inventas)
VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# Configuración del Bot
# ============================================
# Número del dueño/admin para recibir notificaciones (con código de país)
OWNER_PHONE=573001234567

# Nombre de la tabla DynamoDB (se crea automáticamente con SAM)
APPOINTMENTS_TABLE=BigBrotherAppointments
