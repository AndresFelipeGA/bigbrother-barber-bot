# ============================================
# Meta WhatsApp Business Cloud API
# ============================================
# Token de acceso de la WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_api_token_here

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Token personalizado para verificar el webhook (tú lo inventas)
VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# MongoDB Atlas (Free Tier - M0)
# ============================================
# Connection string de MongoDB Atlas
# Formato: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ============================================
# Configuración del Bot
# ============================================
# Número del dueño/admin para recibir notificaciones (con código de país, sin +)
OWNER_PHONE=573001234567

# ============================================
# Web de Reservas - Panel Admin
# ============================================
# Clave de acceso para el panel de administración (/admin)
ADMIN_KEY=bigbrother2024
